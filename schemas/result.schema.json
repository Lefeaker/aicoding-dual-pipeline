{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "summary",
    "completed_task_ids",
    "changed_files",
    "validations",
    "blockers",
    "follow_up"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "completed",
        "partial",
        "blocked"
      ]
    },
    "summary": {
      "type": "string"
    },
    "completed_task_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "command",
          "status",
          "details"
        ],
        "properties": {
          "command": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "passed",
              "failed",
              "not_run"
            ]
          },
          "details": {
            "type": "string"
          }
        }
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "follow_up": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
